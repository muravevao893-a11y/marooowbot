# BotFather token
BOT_TOKEN=8736819022:AAFidymmYqEavtZbomJDKO4DKNGa1ZCGrEE

# Public bot username without @. Needed for deep-links.
BOT_USERNAME=marooowbot

# Channel/chat IDs. Numeric IDs are safest: channel usually starts with -100.
CHANNEL_ID=1003791124367
DISCUSSION_CHAT_ID=1003976665797

# Comma-separated Telegram IDs of admins who can create giveaways.
ADMIN_IDS=7851246214

# PostgreSQL / Redis
DATABASE_URL=postgresql+asyncpg://maroow:maroow@localhost:5432/maroow
REDIS_URL=redis://localhost:6379/0

# Polling is easiest for first launch. Set WEBHOOK_URL to enable webhook mode.
WEBHOOK_URL=
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
WEBHOOK_PATH=/webhook

# Defaults for auto-comment drops
AUTO_DROPS_ENABLED=true
AUTO_DROP_TITLE=Кто хочет мишку?
AUTO_DROP_PRIZE=мишка
AUTO_DROP_GIFT_ID=5170233102089322756
AUTO_DROP_DURATION_SECONDS=7200
AUTO_DROP_MIN_PARTICIPANTS=1
AUTO_DROP_WINNERS=1
REQUIRE_SUBSCRIPTION=true

# Optional: message after sending a Telegram Gift
GIFT_TEXT=забрал от @marooow
